<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cdek.tasktimetracker.dao.TaskDao">

    <resultMap id="TaskResultMap" type="com.cdek.tasktimetracker.entity.Task">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO tasks (title, description, status, created_at, updated_at)
        VALUES (#{title}, #{description}, #{status}, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP)
    </insert>

    <select id="findById" resultMap="TaskResultMap">
        SELECT id, title, description, status, created_at, updated_at
        FROM tasks
        WHERE id = #{id}
    </select>

    <update id="updateStatus">
        UPDATE tasks
        SET status = #{status}, updated_at = CURRENT_TIMESTAMP
        WHERE id = #{id}
    </update>

</mapper>